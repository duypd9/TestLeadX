                const dot = document.createElement('button');
                dot.className = "w-2 h-2 rounded-full flex-shrink-0 transition-all ";
                
                let isAnswered = false;
                if(activePart === 1) {
                    isAnswered = userAnswersPart1[i] && userAnswersPart1[i].most && userAnswersPart1[i].least;
                } else {
                    isAnswered = userAnswersPart2[i] ? true : false;
                }

                if(i === activeQuestionIndex) {
                    dot.className += "bg-blue-600 ring-4 ring-blue-100 scale-125";
                } else if(isAnswered) {
                    dot.className += "bg-emerald-500";
                } else {
                    dot.className += "bg-slate-300 hover:bg-slate-400";
                }

                dot.onclick = () => jumpToQuestion(i);
                container.appendChild(dot);
            }
        }

        function jumpToQuestion(idx) {
            // Validate first if moving forward
            if(idx > activeQuestionIndex) {
                if(!validateCurrentStepAnswer()) return;
            }
            activeQuestionIndex = idx;
            renderCurrentQuestion();
        }

        // VALIDATE ANSWERS FOR PREVENTING BLANK SUBMISSIONS
        function validateCurrentStepAnswer() {
            if(activePart === 1) {
                const ans = userAnswersPart1[activeQuestionIndex];
                if(!ans || !ans.most || !ans.least) {
                    showAlert('Bạn cần chọn đầy đủ 1 phát biểu "Giống nhất" và 1 phát biểu "Ít giống nhất" cho câu hỏi này trước khi tiếp tục!');
                    return false;
                }
            } else {
                const ans = userAnswersPart2[activeQuestionIndex];
                if(!ans) {
                    showAlert('Vui lòng chọn 1 đáp án trước khi tiếp tục!');
                    return false;
                }
            }
            return true;
        }

        // WIZARD NAVIGATION CONTROLS
        function handleNext() {
            if(!validateCurrentStepAnswer()) return;

            if(activePart === 1) {
                if(activeQuestionIndex < 19) {
                    activeQuestionIndex++;
