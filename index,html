<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ Thống Đánh Giá Tố Chất & Tư Duy PM - PO - SA</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#f8fafc',
                            100: '#f1f5f9',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            900: '#1e3a8a',
                        },
                        slate: {
                            800: '#1e293b',
                            900: '#0f172a',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
        body {
            font-family: 'Inter', sans-serif;
        }
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: #f1f1f1;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 3px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
        .draggable-item {
            cursor: grab;
            transition: all 0.2s ease;
        }
        .draggable-item:active {
            cursor: grabbing;
            transform: scale(0.95);
        }
        .drag-over {
            border-color: #2563eb !important;
            background-color: #eff6ff !important;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col justify-between selection:bg-blue-500 selection:text-white">

    <!-- Header -->
    <header class="bg-gradient-to-r from-slate-900 to-indigo-950 text-white py-4 px-4 shadow-lg sticky top-0 z-50 border-b border-indigo-900/30">
        <div class="max-w-6xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-3">
                <div class="bg-blue-600 p-2 rounded-lg shadow-md animate-pulse">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                    </svg>
                </div>
                <div>
                    <h1 class="text-lg md:text-xl font-bold tracking-tight">Học Viện Đào Tạo Khung Năng Lực Quốc Tế</h1>
                    <p class="text-[11px] text-blue-300 font-medium">Hệ Thống Đánh Giá & Tuyển Sinh Nhân Sự Dự Án: PM | PO | SA</p>
                </div>
            </div>
            <div class="flex items-center gap-3">
                <span class="bg-blue-950/80 border border-blue-700/40 text-blue-300 text-xs px-3 py-1.5 rounded-full font-semibold hidden md:inline-block">
                    Standardized Assessment (SHL & GMAT)
                </span>
                <div id="test-timer-wrapper" class="hidden flex items-center gap-2 bg-rose-900/40 border border-rose-500/30 text-rose-300 text-xs px-3 py-1.5 rounded-lg font-mono">
                    <span class="w-2 h-2 rounded-full bg-rose-500 animate-ping"></span>
                    <span>THỜI GIAN:</span>
                    <span id="test-timer" class="font-bold">40:00</span>
                </div>
            </div>
        </div>
    </header>

    <!-- Notification system for errors/warnings instead of alerts -->
    <div id="custom-alert" class="fixed top-20 right-4 left-4 sm:left-auto sm:w-96 bg-white border-l-4 border-rose-500 rounded-r-lg shadow-2xl p-4 z-50 transform translate-x-full transition-transform duration-300 hidden">
        <div class="flex items-start gap-3">
            <div class="text-rose-500 mt-0.5">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <div class="flex-grow">
                <h4 class="font-bold text-gray-900 text-xs uppercase">Cảnh Báo Hệ Thống</h4>
                <p id="custom-alert-msg" class="text-xs text-gray-600 mt-1">Thông báo lỗi chi tiết sẽ xuất hiện tại đây.</p>
            </div>
            <button onclick="closeAlert()" class="text-gray-400 hover:text-gray-600 text-sm font-bold">&times;</button>
        </div>
    </div>

    <!-- Main Content Area -->
    <main class="flex-grow max-w-4xl w-full mx-auto p-4 md:py-6">

        <!-- STEP 1: WELCOME & REGISTRATION -->
        <div id="step-welcome" class="bg-white rounded-2xl shadow-xl border border-slate-100 overflow-hidden transition-all duration-300">
            <div class="bg-gradient-to-r from-blue-700 to-indigo-850 p-6 md:p-10 text-white text-center relative overflow-hidden">
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-blue-500/20 via-transparent to-transparent"></div>
                <span class="bg-indigo-600 text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wider">Tuyển sinh dự án</span>
                <h2 class="text-2xl md:text-4xl font-extrabold mt-3 leading-tight">Đánh Giá Tư Duy Quốc Tế (PM/PO/SA)</h2>
                <p class="mt-4 text-indigo-100 max-w-xl mx-auto text-sm md:text-base leading-relaxed">
                    Hệ thống đánh giá tố chất hành vi (Ipsative Method) và tư duy hệ thống (System Thinking) tiêu chuẩn châu Âu dành riêng cho ba vai trò trụ cột của một dự án công nghệ.
                </p>
            </div>
            
            <div class="p-6 md:p-10">
                <div class="grid md:grid-cols-2 gap-8 mb-8">
                    <div class="space-y-4">
                        <h3 class="font-bold text-gray-900 text-base flex items-center gap-2">
                            <span class="w-2.5 h-2.5 bg-blue-600 rounded-full"></span> Cấu trúc bài đánh giá (40 Câu):
                        </h3>
                        <ul class="space-y-3 text-xs md:text-sm text-gray-600">
                            <li class="flex items-start gap-3">
                                <span class="bg-blue-100 text-blue-600 p-1 rounded-full mt-0.5 text-xs">✔</span>
                                <div>
                                    <strong>Phần 1: Khảo Sát Tố Chất (20 Câu):</strong> Thí sinh lựa chọn hành vi <strong class="text-blue-600">Most (Giống nhất)</strong> và <strong class="text-rose-600">Least (Ít giống nhất)</strong> trong một nhóm ba phát biểu. Giúp định dạng rõ nét tố chất PM, PO hay SA của bạn.
                                </div>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="bg-blue-100 text-blue-600 p-1 rounded-full mt-0.5 text-xs">✔</span>
                                <div>
                                    <strong>Phần 2: Tư Duy Logic (20 Câu):</strong> Đề bài dạng GMAT, McKinsey PST và kiểm định IQ không gian, bao gồm các bài toán giải thuật, tối ưu hóa tài nguyên và chuỗi hình vẽ logic tương tác.
                                </div>
                            </li>
                        </ul>
                    </div>
                    <div class="space-y-4 border-t md:border-t-0 md:border-l border-slate-150 pt-6 md:pt-0 md:pl-8">
                        <h3 class="font-bold text-gray-900 text-base flex items-center gap-2">
                            <span class="w-2.5 h-2.5 bg-blue-600 rounded-full"></span> Quy tắc phòng thi trực tuyến:
                        </h3>
                        <ul class="space-y-2.5 text-xs md:text-sm text-gray-600">
                            <li>⏱️ <strong>Tổng thời gian làm bài:</strong> 40 phút. Đồng hồ sẽ chạy ngay khi bạn ấn Bắt đầu.</li>
                            <li>🔄 <strong>Cơ chế ngẫu nhiên hóa:</strong> Mỗi lần tải lại bài thi sẽ tự tạo mới một tập hợp 40 câu hỏi hoàn toàn khác nhau từ ngân hàng đề.</li>
                            <li>🚫 <strong>Nguyên tắc khách quan:</strong> Hãy làm bài độc lập và trung thực để hệ thống phản ánh đúng kỹ năng hiện tại của bạn.</li>
                        </ul>
                    </div>
                </div>

                <!-- Registration Form -->
                <div class="bg-slate-50 p-6 rounded-2xl border border-slate-200">
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4 text-center">ĐĂNG KÝ THÔNG TIN THÍ SINH</h3>
                    <form id="candidate-form" class="space-y-4 max-w-md mx-auto" onsubmit="event.preventDefault(); startAssessment();">
                        <div class="grid grid-cols-1 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-gray-700 uppercase mb-1">Họ và tên thí sinh</label>
                                <input type="text" id="cand-name" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all text-sm" placeholder="Ví dụ: Nguyễn Văn A">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-700 uppercase mb-1">Địa chỉ Email nhận kết quả</label>
                                <input type="email" id="cand-email" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all text-sm" placeholder="email@domain.com">
                            </div>
                        </div>
                        <button type="submit" class="w-full bg-gradient-to-r from-blue-600 to-indigo-700 hover:from-blue-700 hover:to-indigo-800 text-white font-bold py-3.5 px-6 rounded-xl shadow-lg transition-all transform hover:-translate-y-0.5 active:translate-y-0 text-sm mt-2">
                            Khởi Động Bài Kiểm Tra (40 Câu) 🚀
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- ASSESSMENT ENGINE (HIDDEN BY DEFAULT) -->
        <div id="assessment-container" class="hidden space-y-4">
            
            <!-- Progress Tracker Dashboard -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-150 p-4 flex flex-col md:flex-row justify-between items-center gap-4">
                <div class="flex items-center gap-3">
                    <span class="text-xs font-bold px-2.5 py-1 rounded-full bg-blue-150 text-blue-700 uppercase" id="current-part-badge">PHẦN 1/2</span>
                    <h3 class="font-bold text-slate-800 text-xs md:text-sm" id="part-title-display">Đánh Giá Tố Chất Công Việc</h3>
                </div>
                <div class="w-full md:w-80 flex items-center gap-4">
                    <div class="flex-grow">
                        <div class="flex justify-between text-[11px] text-gray-500 mb-1">
                            <span>Mức độ hoàn thành: <b id="answered-count">0/40</b> câu</span>
                            <span id="progress-percent-text" class="font-bold text-blue-600">0%</span>
                        </div>
                        <div class="w-full bg-slate-100 rounded-full h-2">
                            <div id="progress-bar-fill" class="bg-blue-600 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Wizard Step Card -->
            <div class="bg-white rounded-2xl shadow-lg border border-slate-150 overflow-hidden">
                <div class="bg-slate-900 text-white px-6 py-3.5 flex justify-between items-center text-xs border-b border-slate-800">
                    <span class="font-bold tracking-wider text-blue-400" id="wizard-question-title">CÂU HỎI SỐ 1 / 20</span>
                    <span class="text-slate-400 font-mono" id="wizard-category">Nhận thức vai trò & Hành xử</span>
                </div>

                <div class="p-6 md:p-8" id="wizard-body-content">
                    <!-- Dynamic Question UI injected here by Javascript -->
                </div>

                <!-- Wizard Navigation Footer -->
                <div class="bg-slate-50 px-6 py-4 border-t border-slate-150 flex justify-between items-center">
                    <button id="btn-prev" onclick="handlePrev()" class="bg-white hover:bg-slate-100 text-slate-700 border border-slate-300 font-bold py-2.5 px-5 rounded-xl text-xs transition-all flex items-center gap-1">
                        ❮ Quay lại
                    </button>
                    
                    <div class="flex items-center gap-1.5 overflow-x-auto max-w-[50%] py-1" id="question-dots">
                        <!-- Tiny visual dots representing question indices -->
                    </div>

                    <button id="btn-next" onclick="handleNext()" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2.5 px-6 rounded-xl text-xs shadow transition-all flex items-center gap-1">
                        Tiếp theo ➔
                    </button>
                </div>
            </div>
        </div>

        <!-- RESULTS REPORT PAGE (HIDDEN BY DEFAULT) -->
        <div id="results-container" class="hidden space-y-6">
            <div class="bg-white rounded-2xl shadow-xl border border-slate-150 overflow-hidden">
                <!-- Top Summary Card -->
                <div class="bg-gradient-to-br from-slate-900 via-slate-950 to-indigo-950 p-6 md:p-8 text-white relative">
                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-indigo-500/10 via-transparent to-transparent"></div>
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
                        <div>
                            <span class="bg-indigo-600 text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider">Hồ Sơ Năng Lực Trực Tuyến</span>
                            <h2 class="text-2xl md:text-3xl font-extrabold mt-2 tracking-tight" id="res-cand-name">Họ Tên Thí Sinh</h2>
                            <p class="text-xs text-indigo-300 mt-1" id="res-cand-email">email@test.com</p>
                        </div>
                        <div class="flex gap-4">
                            <div class="bg-white/5 backdrop-blur-md rounded-xl p-4 border border-white/10 text-center min-w-[120px]">
                                <p class="text-[10px] text-indigo-300 uppercase font-semibold tracking-wider">Tư duy Logic</p>
                                <p class="text-2xl md:text-3xl font-black text-emerald-400 mt-1" id="res-logic-score">0 / 100</p>
                                <p class="text-[9px] text-slate-400">GMAT & IQ Standard</p>
                            </div>
                            <div class="bg-white/5 backdrop-blur-md rounded-xl p-4 border border-white/10 text-center min-w-[120px]">
                                <p class="text-[10px] text-indigo-300 uppercase font-semibold tracking-wider">Mức độ tương thích</p>
                                <p class="text-2xl md:text-3xl font-black text-indigo-400 mt-1" id="res-affinity-score">92%</p>
                                <p class="text-[9px] text-slate-400">Role Matching</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="p-6 md:p-8 space-y-8">
                    <!-- Recommended Role Banner -->
                    <div class="bg-blue-50 border border-blue-200 rounded-2xl p-5 flex flex-col md:flex-row items-center gap-5">
                        <div class="bg-blue-600 text-white rounded-2xl p-3 flex-shrink-0 shadow-lg">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
                            </svg>
                        </div>
                        <div class="text-center md:text-left flex-grow">
                            <span class="text-[10px] uppercase font-extrabold text-blue-700 tracking-widest block">KHUYẾN NGHỊ PHÂN VAI TRÒ TỐI ƯU</span>
                            <h3 class="text-xl md:text-2xl font-black text-slate-900 mt-1 leading-tight" id="res-recommended-role">Project Manager (PM)</h3>
                            <p class="text-xs md:text-sm text-slate-600 mt-1.5 leading-relaxed" id="res-role-brief">Mô tả tóm tắt tính cách và năng lực thiên hướng của thí sinh.</p>
                        </div>
                    </div>

                    <!-- Role Matching Graph -->
                    <div class="space-y-4">
                        <h4 class="font-bold text-slate-900 text-sm md:text-base flex items-center gap-1.5">
                            📊 Biểu đồ Đối Chiếu Phân Bổ Tố Chất Hành Vi
                        </h4>
                        <p class="text-xs text-slate-500">Được đo lường bằng việc ép buộc chọn Most/Least giữa các nhóm chỉ số làm việc khác nhau.</p>
                        
                        <div class="space-y-4 pt-2">
                            <!-- PM Bar -->
                            <div class="space-y-1">
                                <div class="flex justify-between text-xs font-semibold">
                                    <span class="text-blue-700 flex items-center gap-1.5">
                                        <span class="w-2.5 h-2.5 bg-blue-600 rounded-sm"></span> PM - Quản Trị Dự Án (Project Manager)
                                    </span>
                                    <span id="pm-pct" class="font-bold font-mono">0%</span>
                                </div>
                                <div class="w-full bg-slate-100 h-4 rounded-full overflow-hidden">
                                    <div id="pm-bar" class="bg-blue-600 h-full rounded-full transition-all duration-1000" style="width: 0%"></div>
                                </div>
                            </div>
                            <!-- PO Bar -->
                            <div class="space-y-1">
                                <div class="flex justify-between text-xs font-semibold">
                                    <span class="text-indigo-700 flex items-center gap-1.5">
                                        <span class="w-2.5 h-2.5 bg-indigo-600 rounded-sm"></span> PO - Quản Trị Sản Phẩm (Product Owner)
                                    </span>
                                    <span id="po-pct" class="font-bold font-mono">0%</span>
                                </div>
                                <div class="w-full bg-slate-100 h-4 rounded-full overflow-hidden">
                                    <div id="po-bar" class="bg-indigo-600 h-full rounded-full transition-all duration-1000" style="width: 0%"></div>
                                </div>
                            </div>
                            <!-- SA Bar -->
                            <div class="space-y-1">
                                <div class="flex justify-between text-xs font-semibold">
                                    <span class="text-purple-700 flex items-center gap-1.5">
                                        <span class="w-2.5 h-2.5 bg-purple-600 rounded-sm"></span> SA - Kiến Trúc Sư Hệ Thống (System Architect)
                                    </span>
                                    <span id="sa-pct" class="font-bold font-mono">0%</span>
                                </div>
                                <div class="w-full bg-slate-100 h-4 rounded-full overflow-hidden">
                                    <div id="sa-bar" class="bg-purple-600 h-full rounded-full transition-all duration-1000" style="width: 0%"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Detailed Analysis Paragraphs -->
                    <div class="border-t border-slate-150 pt-6 grid md:grid-cols-2 gap-6">
                        <div class="bg-slate-50 rounded-2xl p-5 border border-slate-200">
                            <h5 class="font-bold text-slate-900 text-sm flex items-center gap-2 mb-3">
                                🧠 Phân Tích Logic & Giải Quyết Vấn Đề
                            </h5>
                            <p class="text-xs md:text-sm text-slate-600 leading-relaxed" id="res-logic-analysis">
                                Nội dung phân tích khả năng tư duy logic và tiềm năng dựa vào điểm bài thi logic GMAT của thí sinh.
                            </p>
                        </div>
                        <div class="bg-slate-50 rounded-2xl p-5 border border-slate-200">
                            <h5 class="font-bold text-slate-900 text-sm flex items-center gap-2 mb-3">
                                🚀 Khuyến Nghị Lộ Trình Đào Tạo
                            </h5>
                            <p class="text-xs md:text-sm text-slate-600 leading-relaxed" id="res-training-pathway">
                                Khuyến nghị lộ trình đào tạo chuyên biệt dựa trên sự kết hợp hoàn hảo giữa kỹ năng tính cách thực tế và khả năng xử lý bài toán logic thực tế.
                            </p>
                        </div>
                    </div>

                    <!-- REVIEW DETAILED ANSWERS -->
                    <div class="border-t border-slate-150 pt-6">
                        <h4 class="font-bold text-slate-900 text-base mb-4 flex items-center gap-1.5">
                            🔍 Xem Lại & Đối Chiếu Chi Tiết Phần Tư Duy Logic
                        </h4>
                        <p class="text-xs text-gray-500 mb-4">Các câu trả lời đúng được đánh dấu bằng màu xanh lá, câu trả lời sai được đánh dấu màu đỏ kèm theo lời giải thích chuyên môn chi tiết.</p>
                        
                        <div class="space-y-4" id="answers-review-list">
                            <!-- Injected dynamically on completion -->
                        </div>
                    </div>

                    <!-- Footer Actions -->
                    <div class="border-t border-slate-150 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4">
                        <p class="text-xs text-gray-400">Kết quả này được tạo tự động bởi hệ thống đánh giá tuyển sinh năng lực quốc tế.</p>
                        <div class="flex gap-3 w-full sm:w-auto">
                            <button onclick="resetAssessment()" class="w-full sm:w-auto bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold py-2.5 px-5 rounded-xl text-xs transition-all">
