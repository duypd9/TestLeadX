        function submitAssessment() {
            clearInterval(testTimerInterval);

            // Calculate Logical Score (Each correct is worth 5 points -> total 100)
            let correctCount = 0;
            let logicDetailReviewHtml = "";

            testQuestionsPart2.forEach((q, idx) => {
                const userAns = userAnswersPart2[idx] || 'Chưa trả lời';
