                                ${q.matrix.map((cellSvg, cIdx) => {
                                    if(cIdx === 8) {
                                        return `<div class="w-10 h-10 border border-dashed border-blue-400 bg-blue-50 flex items-center justify-center">${getSvgForOption(userAns, q)}</div>`;
                                    } else {
                                        return `<div class="w-10 h-10 bg-slate-50 flex items-center justify-center">${cellSvg}</div>`;
                                    }
                                }).join('')}
                            </div>
                        </div>
                    `;
                }

                logicDetailReviewHtml += `
                    <div class="border rounded-2xl p-4 md:p-5 ${statusColor} space-y-3">
                        <div class="flex justify-between items-start gap-4 text-xs">
                            <span class="font-bold text-slate-500 uppercase tracking-wider">CÂU HỎI ${idx + 1} (${q.category})</span>
                            ${statusBadge}
                        </div>
                        <p class="font-semibold text-slate-900 text-sm leading-relaxed">${q.question}</p>
                        
                        ${visualGridHtml}

                        <div class="grid sm:grid-cols-2 gap-2 text-xs">
                            ${q.options.map(opt => {
                                const selectedMarker = opt.key === userAns ? '➔ ' : '';
                                const weightStyle = opt.key === q.correct ? 'font-bold text-emerald-600 bg-white border border-emerald-300 p-2 rounded-lg flex items-center gap-2' : (opt.key === userAns ? 'font-bold text-rose-600 bg-white border border-rose-300 p-2 rounded-lg flex items-center gap-2' : 'text-slate-500 p-2 flex items-center gap-2');
                                return `
                                    <div class="${weightStyle}">
                                        <span>${selectedMarker}${opt.key}. ${opt.text}</span>
                                        ${q.isVisual ? `<div class="w-8 h-8 ml-auto flex-shrink-0 bg-slate-50 rounded border border-slate-200 flex items-center justify-center">${opt.svg}</div>` : ''}
                                    </div>
                                `;
                            }).join('')}
                        </div>
                        <div class="bg-white/70 rounded-xl p-3 text-xs border border-slate-200/50 mt-2">
                            <strong class="text-indigo-900">Giải thích chi tiết:</strong> ${q.explanation}
                        </div>
                    </div>
                `;
            });

            const logicScore = correctCount * 5;

            // Calculate Personality Affinity Points
            let rawTally = { PM: 0, PO: 0, SA: 0 };

            for(let i = 0; i < 20; i++) {
                const ans = userAnswersPart1[i];
                if(ans) {
                    if(ans.most) rawTally[ans.most] += 2;
                    if(ans.least) rawTally[ans.least] -= 1;
                }
            }

            // Normalization to percentages
            let pmNorm = Math.max(0, rawTally.PM + 20);
            let poNorm = Math.max(0, rawTally.PO + 20);
            let saNorm = Math.max(0, rawTally.SA + 20);
            const totalNorm = pmNorm + poNorm + saNorm;

            let pmPct = 33, poPct = 33, saPct = 34;
            if(totalNorm > 0) {
                pmPct = Math.round((pmNorm / totalNorm) * 100);
                poPct = Math.round((poNorm / totalNorm) * 100);
                saPct = 100 - (pmPct + poPct);
            }

            // Determine Optimal Recommended Role
            let optimalRole = "";
            let brief = "";
            let path = "";
            let maxVal = Math.max(pmPct, poPct, saPct);

            if(maxVal === pmPct) {
                optimalRole = "Project Manager (PM) - Quản Trị Dự Án Chuyên Nghiệp";
                brief = "Tố chất hành vi của bạn thể hiện sự vượt trội trong việc quản trị rủi ro, tối ưu hóa quy trình phân rã công việc (WBS), kiểm soát lịch trình làm việc và điều phối dung hòa các xung đột lợi ích nhân sự. Bạn có xu hướng hành động có kỷ luật thép, tôn trọng thời hạn bàn giao và thích giữ vững sự ổn định.";
                path = "Lộ trình đề xuất: Chuyên sâu hóa Agile/Scrum Master Masterclass, Quản trị chi phí đầu tư dự án CNTT và Nghệ thuật lãnh đạo không chức danh (Lateral Leadership).";
            } else if(maxVal === poPct) {
                optimalRole = "Product Owner (PO) - Quản Trị Sản Phẩm Xuất Sắc";
                brief = "Bạn có xu hướng say mê nghiên cứu hành vi khách hàng, nhạy bén tuyệt vời trước các biến động của thị trường kinh doanh và luôn mong muốn tối đa hóa tỷ suất ROI của từng tính năng phát triển. Bạn có tư duy sáng tạo dồi dào, sẵn sàng thử nghiệm nhanh (prototyping) và thấu hiểu sâu sắc cách thức biến mã nguồn thành tiền tệ.";
                path = "Lộ trình đề xuất: Khóa huấn luyện Product Discovery nâng cao, Phân tích chỉ số tăng trưởng Product-Led Growth (PLG) và Mô phỏng tương tác UI/UX thực tế.";
            } else {
                optimalRole = "System Architect (SA) - Kiến Trúc Sư Hệ Thống Chiến Lược";
                brief = "Tư duy của bạn sinh ra để kiến tạo thế giới cấu trúc. Bạn bị thôi thúc bởi việc tối ưu hóa hiệu năng, bảo vệ độ toàn vẹn của dữ liệu và thiết lập nền tảng hạ tầng công nghệ bền vững, có khả năng mở rộng không giới hạn. Bạn tôn sùng tính logic khách quan, tư duy hệ thống mạch lạc và các nguyên lý lập trình chuẩn mực.";
                path = "Lộ trình đề xuất: Thiết kế hệ thống chịu tải siêu lớn (Microservices), An toàn bảo mật thông tin hạ tầng điện toán đám mây và Standardized API Design patterns.";
            }

            // GMAT Score rating text
            let logicTextRating = "";
            if(logicScore >= 90) {
                logicTextRating = "Thành tích xuất sắc thuộc nhóm 5% ứng viên dẫn đầu thế giới (chuẩn GMAT 750+). Bạn có năng lực tư duy giải thuật tối ưu, phân tích nhạy bén dữ liệu kinh doanh phức tạp và có khả năng ra quyết định hệ thống chuẩn xác dưới áp lực cao.";
            } else if(logicScore >= 70) {
                logicTextRating = "Kết quả xuất sắc chuẩn GMAT 650+. Bạn giải quyết tốt các bài toán ràng buộc tài nguyên hệ thống, định hướng thuật toán mạch lạc và nhạy bén với thông số kinh tế số học.";
            } else if(logicScore >= 50) {
                logicTextRating = "Đạt mức trung bình khá chuẩn quốc tế. Bạn xử lý ổn các bài toán đơn mục tiêu nhưng cần rèn luyện thêm phương pháp bóc tách đa biến và tư duy tối ưu hóa hạ tầng dưới áp lực hạn hẹp của tài nguyên.";
            } else {
                logicTextRating = "Kết quả ở mức cần cải thiện nhiều. Bạn nên tập trung học các kỹ năng cấu trúc hóa tư duy, nâng cao thuật toán cơ bản và học cách đọc hiểu biểu đồ kinh tế trước khi bước vào đào tạo chuyên sâu.";
            }

            // Calculate Dynamic Matching Affinity score
            let affinity = Math.min(99, Math.round(50 + (maxVal * 0.5) + (logicScore * 0.2)));

            // POPULATE TO DOM ELEMENTS
            document.getElementById('res-cand-name').innerText = candName;
            document.getElementById('res-cand-email').innerText = candEmail;
            document.getElementById('res-logic-score').innerText = `${logicScore} / 100`;
            document.getElementById('res-affinity-score').innerText = `${affinity}%`;
            document.getElementById('res-recommended-role').innerText = optimalRole;
            document.getElementById('res-role-brief').innerText = brief;
            document.getElementById('res-logic-analysis').innerText = logicTextRating;
            document.getElementById('res-training-pathway').innerText = path;

            // Update Graph progress bars
            document.getElementById('pm-pct').innerText = `${pmPct}%`;
            document.getElementById('pm-bar').style.width = `${pmPct}%`;
            document.getElementById('po-pct').innerText = `${poPct}%`;
            document.getElementById('po-bar').style.width = `${poPct}%`;
            document.getElementById('sa-pct').innerText = `${saPct}%`;
            document.getElementById('sa-bar').style.width = `${saPct}%`;

            // Inject detailed logic test answers review
            document.getElementById('answers-review-list').innerHTML = logicDetailReviewHtml;

            // Switch UI container view
            document.getElementById('assessment-container').classList.add('hidden');
            document.getElementById('test-timer-wrapper').classList.add('hidden');
            document.getElementById('results-container').classList.remove('hidden');

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // AUTO FORCE SUBMISSION ON TIMEOUT
        function forceAutoSubmit() {
            for(let i = 0; i < 20; i++) {
                if(!userAnswersPart1[i]) {
                    userAnswersPart1[i] = { most: 'PM', least: 'PO' };
                }
                if(!userAnswersPart2[i]) {
                    userAnswersPart2[i] = 'A'; // defaults to A
                }
            }
            submitAssessment();
        }

        // RESET AND RESTART WHOLE SESSION
        function resetAssessment() {
            document.getElementById('cand-name').value = '';
            document.getElementById('cand-email').value = '';
            
            userAnswersPart1 = {};
            userAnswersPart2 = {};
            activePart = 1;
            activeQuestionIndex = 0;

            const wrapper = document.getElementById('test-timer-wrapper');
            wrapper.classList.add('bg-rose-900/40', 'text-rose-300');
            wrapper.classList.remove('bg-rose-600', 'text-white', 'animate-bounce');

            document.getElementById('results-container').classList.add('hidden');
            document.getElementById('step-welcome').classList.remove('hidden');

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
</body>
</html>
