            radios.forEach(radio => {
                if(radio.value === optionKey) {
                    radio.checked = true;
                    // Highlight outer box
                    radio.closest('label').classList.add('border-blue-500', 'bg-blue-50/50', 'ring-2', 'ring-blue-100');
                } else {
                    radio.closest('label').classList.remove('border-blue-500', 'bg-blue-50/50', 'ring-2', 'ring-blue-100');
