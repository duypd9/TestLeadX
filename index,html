        // SET VALUE: Ipsative selection logic
        function setIpsativeValue(stmtIdx, type) {
            const qData = testQuestionsPart1[activeQuestionIndex];
            const chosenRole = qData.statements[stmtIdx].role;

            if(!userAnswersPart1[activeQuestionIndex]) {
                userAnswersPart1[activeQuestionIndex] = { most: '', least: '' };
            }

            const currentObj = userAnswersPart1[activeQuestionIndex];
            const otherType = type === 'most' ? 'least' : 'most';

            // Mutual exclusion rule check
            if(currentObj[otherType] === chosenRole) {
                currentObj[otherType] = ''; // Reset the other side
            }

            currentObj[type] = chosenRole;
            renderCurrentQuestion();
        }

        // SET VALUE: Logical selection logic
        function setLogicalValue(optionKey) {
            userAnswersPart2[activeQuestionIndex] = optionKey;
            
