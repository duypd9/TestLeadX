                    // Transition from Part 1 to Part 2
                    activePart = 2;
                    activeQuestionIndex = 0;
                    showAlert('Bạn đã hoàn thành Phần 1. Hệ thống đang chuyển hướng sang Phần 2: Đánh giá Tư duy Logic!');
                }
                renderCurrentQuestion();
            } else {
                if(activeQuestionIndex < 19) {
                    activeQuestionIndex++;
                    renderCurrentQuestion();
                } else {
                    // Submit final exam
                    submitAssessment();
                }
            }
        }

